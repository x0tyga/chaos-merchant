# API Keys
ANTHROPIC_API_KEY=sk-ant-...
YOUTUBE_API_KEY=your-youtube-api-key
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=chaos-merchant/1.0

# Voice Synthesis (Kokoro primary - free and local)
# Valid kokoro-onnx v1.0 voices: af_heart, af_bella, af_nicole, af_aoede,
# am_adam, am_michael, bf_emma, bm_george
KOKORO_VOICE=af_bella
# ELEVENLABS_API_KEY=sk_... (OPTIONAL: Premium voice upgrade, not required)
# ELEVENLABS_VOICE_ID=your-voice-id (OPTIONAL: With ElevenLabs API key)

# Google Trends (free, no key needed for basic access)
# GOOGLE_TRENDS_API_KEY=optional

# Directories (pre-filled for Mac Mini setup - update if you move the project folder)
INPUT_DIR=/Users/tyler/Desktop/chaos-merchant/input
OUTPUT_DIR=/Users/tyler/Desktop/chaos-merchant/output
DATA_DIR=/Users/tyler/Desktop/chaos-merchant/data

# Video Processing
WHISPER_MODEL=base
TARGET_SHORTS_COUNT=7

# Clip Duration Optimization (shorter clips = faster completion rate at launch)
MIN_CLIP_DURATION=15
MAX_CLIP_DURATION=45

# Clip Selection - minimum viral score (0-10 scale) a segment should clear to
# be preferred for selection. Segments are still selected via backfill even if
# none clear this bar, so clip selection never silently returns 0 clips.
VIRAL_SCORE_THRESHOLD=3.0

# Channel Branding
CHANNEL_NAME=Chaos Merchant

# Background music bed (source video audio is ALWAYS stripped completely;
# final audio = voiceover + one royalty-free track from this folder, looped/
# trimmed to the clip, rotating per short. Empty folder = voiceover only.)
BACKGROUND_MUSIC_DIR=./assets/music

# Music levels (dB relative to the track's own volume; music never plays at
# full volume). BASE applies outside the voiceover, DUCK during it, with
# short ramps between the two so there's no audible click.
MUSIC_BASE_DB=-12
MUSIC_DUCK_DB=-18

# Video Production - Caption Styling
# Optional: Set to path of TrueType font file (.ttf) for custom captions
# Examples: /path/to/BebasNeue-Regular.ttf or C:\Fonts\BebasNeue-Regular.ttf
# If not set, uses system default font (recommended before home machine testing)
# CAPTION_FONT_PATH=/usr/share/fonts/truetype/bebas-neue/BebasNeue-Regular.ttf

# Processing
PROCESSING_TIMEOUT_SECONDS=3600

# Notifications
ENABLE_NOTIFICATIONS=true

# Database (informational only - actual path is always DATA_DIR/chaos_merchant.db,
# derived automatically from DATA_DIR above; this var is not read directly by the code)
DATABASE_PATH=/Users/tyler/Desktop/chaos-merchant/data/chaos_merchant.db

# Logging (dashboard's Logs page tails LOG_DIR/chaos_merchant.log)
LOG_DIR=./logs

# Dashboard (dashboard/app.py - Flask, edit .env and prompt files in-browser)
# Binds to 127.0.0.1 by default - this is a single-user local tool with no
# authentication, do not set DASHBOARD_HOST=0.0.0.0 on a shared network
# without adding your own auth in front of it.
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=5050

# Publisher - all three platforms OFF by default. Flip to 'true' only once
# that platform's credentials below are actually configured and verified.
AUTO_POST_YOUTUBE=false
AUTO_POST_TIKTOK=false
AUTO_POST_INSTAGRAM=false

# YouTube upload (OAuth, separate from YOUTUBE_API_KEY above which is
# read-only/public). Run: python -m core.publisher setup-youtube
YOUTUBE_OAUTH_CLIENT_SECRETS=./config/youtube_client_secrets.json
YOUTUBE_UPLOAD_TOKEN_PATH=./data/youtube_upload_token.json

# YouTube Analytics (OAuth, private metrics - impressions/AVD/retention).
# Run: python -m agents.analytics_feedback setup
YOUTUBE_ANALYTICS_TOKEN_PATH=./data/youtube_analytics_token.json

# TikTok Content Posting API - requires an approved TikTok dev app; TikTok's
# OAuth needs a real HTTPS redirect (no localhost flow), so obtain these
# externally and paste them here.
# TIKTOK_ACCESS_TOKEN=
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=

# Instagram Graph API - requires a Meta Business app + Instagram
# Professional account linked to a Facebook Page. The Graph API fetches
# your video FROM a public URL, so PUBLIC_VIDEO_BASE_URL must point at
# wherever finished shorts are actually reachable over HTTPS.
# INSTAGRAM_ACCESS_TOKEN=
# INSTAGRAM_BUSINESS_ACCOUNT_ID=
# PUBLIC_VIDEO_BASE_URL=
