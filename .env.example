# API Keys
ANTHROPIC_API_KEY=sk-ant-...
YOUTUBE_API_KEY=your-youtube-api-key
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=chaos-merchant/1.0

# Voice Synthesis (Kokoro primary - free and local)
# Valid kokoro-onnx v1.0 voices: af_heart, af_bella, af_nicole, af_aoede,
# am_adam, am_michael, bf_emma, bm_george
KOKORO_VOICE=af_bella
# ELEVENLABS_API_KEY=sk_... (OPTIONAL: Premium voice upgrade, not required)
# ELEVENLABS_VOICE_ID=your-voice-id (OPTIONAL: With ElevenLabs API key)

# Google Trends (free, no key needed for basic access)
# GOOGLE_TRENDS_API_KEY=optional

# Directories (pre-filled for Mac Mini setup - update if you move the project folder)
INPUT_DIR=/Users/tyler/Desktop/chaos-merchant/input
OUTPUT_DIR=/Users/tyler/Desktop/chaos-merchant/output
DATA_DIR=/Users/tyler/Desktop/chaos-merchant/data

# Video Processing
WHISPER_MODEL=base
TARGET_SHORTS_COUNT=7

# Clip Duration Optimization (shorter clips = faster completion rate at launch)
MIN_CLIP_DURATION=15
MAX_CLIP_DURATION=45

# Clip Selection - minimum viral score (0-10 scale) a segment should clear to
# be preferred for selection. Segments are still selected via backfill even if
# none clear this bar, so clip selection never silently returns 0 clips.
VIRAL_SCORE_THRESHOLD=3.0

# Multi-format script system - Reaction/Commentary is gated to only clips
# clearing this viral_score (0-10 scale) - see agents/format_selector.py.
REACTION_MIN_VIRAL_SCORE=8.0

# Below this self-reported confidence (0.0-1.0) in the clip's vision
# content description, the format selector skips its LLM tiebreak entirely
# and defaults to Hidden Details rather than risk a format decision based
# on a vague/wrong description - see agents/format_selector.py.
FORMAT_SELECTOR_MIN_DESCRIPTION_CONFIDENCE=0.5

# A source video at or below this duration is treated as already
# short-form (e.g. a sourced Reddit/YouTube clip) and mapped to a single
# Short instead of being sliced by scene-detection into multiple clips -
# see agents/clip_intelligence.py's analyze_video().
SHORT_CLIP_MAX_SECONDS=90

# Autonomous Clip Sourcing (agents/clip_sourcing.py) - finds and downloads
# its own source footage from Reddit + YouTube on a schedule, so the input
# folder never needs a manual video drop. Twitter/X is deliberately not
# sourced (no existing credentials/library, and its API now requires a
# paid tier) - see HANDOFF.md for the full scoping discussion.
# Reuses REDDIT_CLIENT_ID/SECRET/USER_AGENT above - no separate credentials needed.

# Copyright/quality gate - ALL THREE must pass before a clip is downloaded
# at all, since sourced batches publish with no human review in between:
MIN_REDDIT_SCORE=500
MIN_YOUTUBE_VIEWS=50000
MAX_SOURCE_CLIP_SECONDS=180
MIN_SOURCE_RESOLUTION_HEIGHT=480

# Quality Gate Tier 2 (post-download): the checks above only ever inspect
# what yt-dlp's probe REPORTED before downloading - this validates the
# actual downloaded file (real video stream, sane duration) before it
# reaches the pipeline. MAX_SOURCE_CLIP_SECONDS above is reused here too,
# on purpose - one number, not two that can drift apart.
MIN_SOURCE_DOWNLOAD_SECONDS=5

# Download behavior
SOURCING_MAX_DOWNLOAD_HEIGHT=1080
SOURCING_MAX_DOWNLOADS_PER_RUN=5
SOURCING_MAX_PROBES_PER_RUN=30
SOURCING_REQUEST_DELAY_SECONDS=2

# yt-dlp downloads have no metered API fee, but the bytes transferred are a
# real cost IF this is running on infrastructure that bills egress/bandwidth
# (a cloud VM) - NOT true on the documented home-machine deployment, which
# has no metered network. Left at 0.0 (honest default - $0 real cost on a
# home machine); set to a real $/GB figure only if deployed somewhere that
# actually bills for it. Feeds core/cost_tracker.py's cost-per-Short metric
# alongside Anthropic API spend - see core/posting_queue.py.
DOWNLOAD_COST_PER_GB_USD=0.0

# Channel Branding
CHANNEL_NAME=Chaos Merchant

# Background music bed (source video audio is ALWAYS stripped completely;
# final audio = voiceover + one royalty-free track from this folder, looped/
# trimmed to the clip, rotating per short. Empty folder = voiceover only.)
BACKGROUND_MUSIC_DIR=./assets/music

# Music levels (dB relative to the track's own volume; music never plays at
# full volume). BASE applies outside the voiceover, DUCK during it, with
# short ramps between the two so there's no audible click.
MUSIC_BASE_DB=-12
MUSIC_DUCK_DB=-18

# Video Production - Caption Styling
# Optional: Set to path of TrueType font file (.ttf) for custom captions
# Examples: /path/to/BebasNeue-Regular.ttf or C:\Fonts\BebasNeue-Regular.ttf
# moviepy 2.x's TextClip has NO built-in default font (unlike 1.x's
# ImageMagick-backed version) - if this is unset, CaptionSynchronizer falls
# back through a hardcoded candidate list (DejaVu/Liberation on Linux,
# system fonts on macOS) and captions will only fail if NONE of those exist
# on disk either. Still recommended to set this explicitly to a real
# gaming-style font before home machine testing rather than relying on the
# fallback. Find an installed font path with: fc-list | grep -i dejavu
# CAPTION_FONT_PATH=/usr/share/fonts/truetype/bebas-neue/BebasNeue-Regular.ttf

# Processing
PROCESSING_TIMEOUT_SECONDS=3600

# Notifications
ENABLE_NOTIFICATIONS=true

# Database (informational only - actual path is always DATA_DIR/chaos_merchant.db,
# derived automatically from DATA_DIR above; this var is not read directly by the code)
DATABASE_PATH=/Users/tyler/Desktop/chaos-merchant/data/chaos_merchant.db

# Logging (dashboard's Logs page tails LOG_DIR/chaos_merchant.log)
LOG_DIR=./logs

# Dashboard (dashboard/app.py - Flask, edit .env and prompt files in-browser)
# Binds to 127.0.0.1 by default - this is a single-user local tool with no
# authentication, do not set DASHBOARD_HOST=0.0.0.0 on a shared network
# without adding your own auth in front of it.
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=5050

# Publisher - all three platforms OFF by default. Flip to 'true' only once
# that platform's credentials below are actually configured and verified.
#
# AUTO_POST_YOUTUBE is NOT a review queue - it is a one-time safety switch
# for first launch. While false, finished/QC-passed batches are still
# queued (core/posting_queue.py) at spaced-out scheduled times, but never
# actually uploaded. The moment this is set to true, the queue drains on
# its own schedule (POSTING_QUEUE_DRAIN_MINUTES below) and every due Short
# posts to YouTube automatically, with zero human review, forever - until
# this is switched back to false. Before enabling: run
# `python -m core.publisher setup-youtube` once to authorize uploads, make
# sure config/source_channels.json / source_subreddits.json reflect content
# you actually want to publish under this channel, and review at least one
# full batch's output manually first.
AUTO_POST_YOUTUBE=false
AUTO_POST_TIKTOK=false
AUTO_POST_INSTAGRAM=false

# How often (minutes) core/posting_queue.py's drain job checks for due
# scheduled posts. Only matters once AUTO_POST_YOUTUBE=true - checked fresh
# on every tick (not cached), so toggling AUTO_POST_YOUTUBE takes effect on
# the next tick without restarting the process.
POSTING_QUEUE_DRAIN_MINUTES=15

# YouTube upload (OAuth, separate from YOUTUBE_API_KEY above which is
# read-only/public). Run: python -m core.publisher setup-youtube
YOUTUBE_OAUTH_CLIENT_SECRETS=./config/youtube_client_secrets.json
YOUTUBE_UPLOAD_TOKEN_PATH=./data/youtube_upload_token.json

# YouTube Analytics (OAuth, private metrics - impressions/AVD/retention).
# Run: python -m agents.analytics_feedback setup
YOUTUBE_ANALYTICS_TOKEN_PATH=./data/youtube_analytics_token.json

# TikTok Content Posting API - requires an approved TikTok dev app; TikTok's
# OAuth needs a real HTTPS redirect (no localhost flow), so obtain these
# externally and paste them here.
# TIKTOK_ACCESS_TOKEN=
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=

# Instagram Graph API - requires a Meta Business app + Instagram
# Professional account linked to a Facebook Page. The Graph API fetches
# your video FROM a public URL, so PUBLIC_VIDEO_BASE_URL must point at
# wherever finished shorts are actually reachable over HTTPS.
# INSTAGRAM_ACCESS_TOKEN=
# INSTAGRAM_BUSINESS_ACCOUNT_ID=
# PUBLIC_VIDEO_BASE_URL=
