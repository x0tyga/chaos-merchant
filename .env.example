# API Keys
ANTHROPIC_API_KEY=sk-ant-...
YOUTUBE_API_KEY=your-youtube-api-key
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=chaos-merchant/1.0

# Voice Synthesis (Kokoro primary - free and local)
# ELEVENLABS_API_KEY=sk_... (OPTIONAL: Premium voice upgrade, not required)
# ELEVENLABS_VOICE_ID=your-voice-id (OPTIONAL: With ElevenLabs API key)

# Google Trends (free, no key needed for basic access)
# GOOGLE_TRENDS_API_KEY=optional

# Directories (pre-filled for Mac Mini setup - update if you move the project folder)
INPUT_DIR=/Users/tyler/Desktop/chaos-merchant/input
OUTPUT_DIR=/Users/tyler/Desktop/chaos-merchant/output
DATA_DIR=/Users/tyler/Desktop/chaos-merchant/data

# Video Processing
WHISPER_MODEL=base
TARGET_SHORTS_COUNT=7

# Clip Duration Optimization (shorter clips = faster completion rate at launch)
MIN_CLIP_DURATION=15
MAX_CLIP_DURATION=45

# Clip Selection - minimum viral score (0-10 scale) a segment should clear to
# be preferred for selection. Segments are still selected via backfill even if
# none clear this bar, so clip selection never silently returns 0 clips.
VIRAL_SCORE_THRESHOLD=3.0

# Channel Branding
CHANNEL_NAME=Chaos Merchant

# Video Production - Caption Styling
# Optional: Set to path of TrueType font file (.ttf) for custom captions
# Examples: /path/to/BebasNeue-Regular.ttf or C:\Fonts\BebasNeue-Regular.ttf
# If not set, uses system default font (recommended before home machine testing)
# CAPTION_FONT_PATH=/usr/share/fonts/truetype/bebas-neue/BebasNeue-Regular.ttf

# Processing
PROCESSING_TIMEOUT_SECONDS=3600

# Notifications
ENABLE_NOTIFICATIONS=true

# Database (informational only - actual path is always DATA_DIR/chaos_merchant.db,
# derived automatically from DATA_DIR above; this var is not read directly by the code)
DATABASE_PATH=/Users/tyler/Desktop/chaos-merchant/data/chaos_merchant.db
